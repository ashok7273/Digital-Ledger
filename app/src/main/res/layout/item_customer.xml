<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/ivAvatarCircle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_circle_bg"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:contentDescription="Customer photo"/>

            <TextView
                android:id="@+id/tvCustomerInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Customer Name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:singleLine="true"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"/>

        <!-- Balance -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvCustomerBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/label_gray"/>

            <TextView
                android:id="@+id/tvBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="settled"
                android:textSize="10sp"
                android:textColor="@color/hint_gray"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="58dp"
        android:background="@color/divider_gray"/>
</LinearLayout>