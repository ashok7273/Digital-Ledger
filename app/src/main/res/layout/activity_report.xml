<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header row: Back, divider, Report -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnReportBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/baseline_arrow_back_24"
            android:contentDescription="Back"
            android:padding="4dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="14dp"
            android:background="@color/divider_light" />

        <TextView
            android:id="@+id/tvReportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#222222"
            android:gravity="start" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light"
        android:layout_marginBottom="14dp" />

    <!-- Filter chip row (Custom is first) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/reportFilterChipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportFilterCustom"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Custom" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportFilterToday"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Today"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportFilterThisMonth"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="This month"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportFilterThisYear"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="This year"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReportFilterLastYear"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Last year"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Period description -->
    <TextView
        android:id="@+id/tvReportPeriod"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/accent_purple"
        android:layout_marginBottom="10dp" />

    <!-- Result Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Total Given"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_given"/>
                <TextView
                    android:id="@+id/tvReportGiven"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/color_given"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Total Received"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_received"/>
                <TextView
                    android:id="@+id/tvReportReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/color_received"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Net"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:id="@+id/tvReportNet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="14dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>