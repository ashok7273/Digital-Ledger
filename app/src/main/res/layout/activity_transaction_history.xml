<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_bg_rounded"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="34dp"
        android:paddingBottom="18dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/header_icon_bg"
            app:srcCompat="@drawable/baseline_arrow_back_24"
            app:tint="@color/primary_blue"
            android:contentDescription="Back"
            android:padding="7dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvTransactionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaction history"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:maxWidth="220dp"
                android:ellipsize="end"
                android:singleLine="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer transactions"
                android:textSize="11sp"
                android:textColor="@color/text_on_primary_muted"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/filterChipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterOverall"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Overall" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterCustom"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Custom"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterLast7"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Last 7 days"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterThisMonth"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="This month"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterLastMonth"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Last month"
                android:layout_marginStart="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFilterLast3Months"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Last 3 months"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:background="@color/stat_blue_bg">

                <TextView
                    android:id="@+id/headerDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Date"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/primary_blue"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start"/>

                <TextView
                    android:id="@+id/headerGiven"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Given"
                    android:gravity="end"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/color_given"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/headerReceived"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Received"
                    android:gravity="end"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/color_received"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/headerTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total"
                    android:gravity="end"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/deep_purple"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewTransactions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadPdf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Download"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="@color/primary_blue_light"
            android:textColor="@color/primary_blue"
            app:cornerRadius="12dp"
            android:fontFamily="sans-serif-medium"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSharePdf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Share"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="@color/primary_blue"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>
</LinearLayout>