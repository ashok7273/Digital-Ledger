<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg"
    tools:context=".MainActivity">

    <!-- ==================== HEADER (gradient toolbar) ==================== -->
    <LinearLayout
        android:id="@+id/upperContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_bg_rounded"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="34dp"
        android:paddingBottom="18dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:elevation="6dp">

        <FrameLayout
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Business profile"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/ivBusinessProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_circle_bg"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:contentDescription="Business profile photo" />

            <TextView
                android:id="@+id/tvBusinessProfileInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="M"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvBusinessName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Business"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="@color/white"
                android:singleLine="true"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grow Business with VLedger"
                android:textSize="11sp"
                android:textColor="@color/text_on_primary_muted"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ==================== STATS ROW (3 cards) ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp">

        <!-- Customers card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/stat_blue_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:text="Customers"
                    android:textColor="@color/primary_blue"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvTotalCustomers"
                    android:text="0"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:textColor="@color/primary_blue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Due card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/stat_red_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:text="You'll Give"
                    android:textColor="@color/color_given"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvTotalDue"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/color_given"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp"
                    android:singleLine="true"
                    android:ellipsize="end"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Advance card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/stat_green_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:text="You'll Get"
                    android:textColor="@color/color_received"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvTotalAdvance"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/color_received"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp"
                    android:singleLine="true"
                    android:ellipsize="end"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ==================== SEARCH BAR ==================== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/white">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:queryHint="Search customers..."
            android:background="@android:color/transparent"
            android:iconifiedByDefault="false"
            app:iconifiedByDefault="false"
            android:textColorHint="@color/hint_gray"/>
    </androidx.cardview.widget.CardView>

    <!-- ==================== SECTION LABEL ==================== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CUSTOMERS"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/label_gray"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="4dp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"/>

    <!-- ==================== LIST + EMPTY STATE ==================== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewCustomers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/tvEmptyList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No customers yet.&#10;Tap + to add your first one!"
            android:textSize="15sp"
            android:textColor="@color/hint_gray"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:visibility="gone"
            android:fontFamily="sans-serif-medium"/>
    </FrameLayout>

    <!-- ==================== BOTTOM BAR ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:elevation="8dp"
        android:background="@color/white">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnShowReport"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.4"
            android:layout_marginEnd="10dp"
            app:backgroundTint="@color/primary_blue_light"
            app:icon="@drawable/ic_report_24"
            app:iconTint="@color/primary_blue"
            android:text="Report"
            android:textColor="@color/primary_blue"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"/>

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_add_customer"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.6"
            app:backgroundTint="@color/primary_blue"
            app:icon="@drawable/ic_add_24"
            app:iconTint="@color/white"
            android:text="Add Customer"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:contentDescription="Add Customer"/>
    </LinearLayout>
</LinearLayout>