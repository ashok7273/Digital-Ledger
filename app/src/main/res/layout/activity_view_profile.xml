<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- GRADIENT HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_bg_rounded"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="34dp"
        android:paddingBottom="18dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnProfileBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/header_icon_bg"
            app:srcCompat="@drawable/baseline_arrow_back_24"
            app:tint="@color/primary_blue"
            android:contentDescription="Back"
            android:padding="7dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvProfileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Profile"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage customer information"
                android:textSize="11sp"
                android:textColor="@color/text_on_primary_muted"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <!-- PROFILE AVATAR CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <FrameLayout
                        android:id="@+id/profilePhotoContainer"
                        android:layout_width="92dp"
                        android:layout_height="92dp"
                        android:elevation="4dp">

                        <ImageView
                            android:id="@+id/profilePicCircle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/profile_circle_bg"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:contentDescription="Customer profile photo"/>

                        <TextView
                            android:id="@+id/tvProfileLetter"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="A"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Customer Name"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-medium"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CUSTOMER DETAILS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DETAILS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/label_gray"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="10dp"/>

                    <!-- Mobile -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/label_gray"
                        android:fontFamily="sans-serif-medium"/>
                    <EditText
                        android:id="@+id/etProfileMobile"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"
                        android:hint="No mobile"
                        android:textSize="15sp"
                        android:inputType="phone"
                        android:background="@drawable/rounded_edittext"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint_gray"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:fontFamily="sans-serif"/>

                    <!-- Address -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/label_gray"
                        android:fontFamily="sans-serif-medium"/>
                    <EditText
                        android:id="@+id/etProfileAddress"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"
                        android:hint="No address"
                        android:textSize="15sp"
                        android:inputType="textPostalAddress"
                        android:background="@drawable/rounded_edittext"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint_gray"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:fontFamily="sans-serif"/>

                    <!-- Email -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/label_gray"
                        android:fontFamily="sans-serif-medium"/>
                    <EditText
                        android:id="@+id/etProfileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"
                        android:hint="No email"
                        android:textSize="15sp"
                        android:inputType="textEmailAddress"
                        android:background="@drawable/rounded_edittext"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint_gray"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:fontFamily="sans-serif"/>

                    <!-- Aadhar -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aadhar Number"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/label_gray"
                        android:fontFamily="sans-serif-medium"/>
                    <EditText
                        android:id="@+id/etProfileAadhar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"
                        android:hint="12-digit Aadhar"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:background="@drawable/rounded_edittext"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint_gray"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:fontFamily="sans-serif"/>

                    <!-- GST -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GST Number"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/label_gray"
                        android:fontFamily="sans-serif-medium"/>
                    <EditText
                        android:id="@+id/etProfileGST"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:hint="GST number"
                        android:textSize="15sp"
                        android:background="@drawable/rounded_edittext"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint_gray"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SAVE/EDIT BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="Edit Profile"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/primary_blue_light"
                android:textColor="@color/primary_blue"
                app:cornerRadius="16dp"
                android:elevation="1dp"
                android:fontFamily="sans-serif-medium"/>

            <!-- DELETE BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Delete Customer"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/color_given"
                android:textColor="@color/white"
                app:cornerRadius="16dp"
                android:elevation="1dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
