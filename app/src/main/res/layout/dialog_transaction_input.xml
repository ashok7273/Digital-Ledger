<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="20dp"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter amount"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notes (optional)"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Attachment Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Attachment (Optional)"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnAttachCamera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📷 Camera"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            style="?android:attr/buttonBarButtonStyle"/>

        <Button
            android:id="@+id/btnAttachFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📁 Files"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            style="?android:attr/buttonBarButtonStyle"/>

    </LinearLayout>

    <!-- Selected attachment display -->
    <LinearLayout
        android:id="@+id/attachmentPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@color/lightStripeGray"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvAttachmentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selected file"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnRemoveAttachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/color_error"
            android:background="?android:attr/selectableItemBackground"
            android:padding="4dp"/>

    </LinearLayout>

</LinearLayout>